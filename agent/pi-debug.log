[223] (w=84) " \u001b[38;2;240;198;116m\u001b[1m### \u001b[22m\u001b[39m\u001b[38;2;240;198;116m\u001b[1mChanged\u001b[22m\u001b[39m                                                                        "
[224] (w=84) "                                                                                    "
[225] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mUpdated default model selection across providers to current recommended models.  "
[226] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mImproved stale extension context errors after session replacement or reload to   "
[227] (w=84) " tell extension authors to avoid captured \u001b[38;2;138;190;183mpi\u001b[39m/command \u001b[38;2;138;190;183mctx\u001b[39m and use \u001b[38;2;138;190;183mwithSession\u001b[39m for    "
[228] (w=84) " post-replacement work.                                                             "
[229] (w=84) "                                                                                    "
[230] (w=84) " \u001b[38;2;240;198;116m\u001b[1m### \u001b[22m\u001b[39m\u001b[38;2;240;198;116m\u001b[1mFixed\u001b[22m\u001b[39m                                                                          "
[231] (w=84) "                                                                                    "
[232] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183m/model\u001b[39m selector cancellation to request render instead of incorrectly      "
[233] (w=84) " triggering login selector.                                                         "
[234] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mChanged login, OAuth, and extension selectors for more consistent styling.       "
[235] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mAdded Amazon Bedrock setup guidance to \u001b[38;2;138;190;183m/login\u001b[39m and updated \u001b[38;2;138;190;183m/model\u001b[39m copy to refer   "
[236] (w=84) " to configured providers instead of only API keys.                                  "
[237] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mImproved no-model and missing-auth warnings to point users to \u001b[38;2;138;190;183m/login\u001b[39m for OAuth   "
[238] (w=84) " or API key setup.                                                                  "
[239] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183m/quit\u001b[39m shutdown ordering to stop the TUI before extension UI teardown can   "
[240] (w=84) " repaint, preserving the final rendered frame while still emitting \u001b[38;2;138;190;183msession_shutdown "
[241] (w=84) " \u001b[38;2;138;190;183m\u001b[39m before process exit.                                                              "
[242] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183mSettingsManager.inMemory()\u001b[39m initial settings being lost after reloads       "
[243] (w=84) " triggered by SDK resource loading (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3616\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3616\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                          "
[244] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183mmodels.json\u001b[39m provider compatibility to accept                               "
[245] (w=84) " \u001b[38;2;138;190;183mcompat.supportsLongCacheRetention\u001b[39m, allowing proxies to opt out of long-retention   "
[246] (w=84) " cache fields when needed while long retention is enabled by default when requested "
[247] (w=84) " (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3543\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3543\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                                            "
[248] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183m--thinking xhigh\u001b[39m for \u001b[38;2;138;190;183mopenai-codex\u001b[39m \u001b[38;2;138;190;183mgpt-5.5\u001b[39m so it is no longer downgraded to "
[249] (w=84) " \u001b[38;2;138;190;183mhigh\u001b[39m.                                                                              "
[250] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed git package installs with custom \u001b[38;2;138;190;183mnpmCommand\u001b[39m values such as \u001b[38;2;138;190;183mpnpm\u001b[39m by         "
[251] (w=84) " avoiding npm-specific production flags in that compatibility path (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3604\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3604\u001b[24m\u001b[39m\u001b]8;;\u001b\\)          "
[252] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed first user messages rendering without spacing after existing notices such  "
