[297] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed startup banner extension labels to strip trailing \u001b[38;2;138;190;183mindex.js\u001b[39m/\u001b[38;2;138;190;183mindex.ts\u001b[39m        "
