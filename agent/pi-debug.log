[393] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mConfigurable inline tool image width via \u001b[38;2;138;190;183mterminal.imageWidthCells\u001b[39m in \u001b[38;2;138;190;183m/settings\u001b[39m.  "
[394] (w=84) " See \u001b]8;;docs/settings.md#terminal--images\u001b\\\u001b[38;2;129;162;190m\u001b[4mdocs/settings.md#terminal--images\u001b[24m\u001b[39m\u001b]8;;\u001b\\.                                             "
[395] (w=84) "                                                                                    "
[396] (w=84) " \u001b[38;2;240;198;116m\u001b[1m### \u001b[22m\u001b[39m\u001b[38;2;240;198;116m\u001b[1mAdded\u001b[22m\u001b[39m                                                                          "
[397] (w=84) "                                                                                    "
[398] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mAdded built-in Fireworks provider support, including \u001b[38;2;138;190;183mFIREWORKS_API_KEY\u001b[39m           "
[399] (w=84) " setup/docs and the default Fireworks model \u001b[38;2;138;190;183maccounts/fireworks/models/kimi-k2p6\u001b[39m     "
[400] (w=84) " (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3519\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3519\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                                            "
[401] (w=84) "                                                                                    "
[402] (w=84) " \u001b[38;2;240;198;116m\u001b[1m### \u001b[22m\u001b[39m\u001b[38;2;240;198;116m\u001b[1mFixed\u001b[22m\u001b[39m                                                                          "
[403] (w=84) "                                                                                    "
[404] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed interactive inline tool images to honor configurable                       "
[405] (w=84) " \u001b[38;2;138;190;183mterminal.imageWidthCells\u001b[39m via \u001b[38;2;138;190;183m/settings\u001b[39m, so tool-output images are no longer        "
[406] (w=84) " hard-capped to 60 terminal cells (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3508\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3508\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                           "
[407] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183msessionDir\u001b[39m in \u001b[38;2;138;190;183msettings.json\u001b[39m to expand \u001b[38;2;138;190;183m~\u001b[39m, so portable session-directory     "
[408] (w=84) " settings no longer require a shell wrapper (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3514\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3514\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                 "
[409] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed parallel tool-call rows to leave the pending state as soon as each tool is "
[410] (w=84) " finalized, while still appending persisted tool results in assistant source order  "
[411] (w=84) " (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3503\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3503\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                                            "
[412] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed exported session markdown to render Markdown while showing HTML-like       "
[413] (w=84) " message content such as \u001b[38;2;138;190;183m<file name=\"...\">...</file>\u001b[39m verbatim, so shared sessions   "
[414] (w=84) " match the TUI instead of letting the browser interpret message text (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3484\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3484\u001b[24m\u001b[39m\u001b]8;;\u001b\\)        "
[415] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed exported session HTML to render \u001b[38;2;138;190;183mgrep\u001b[39m and \u001b[38;2;138;190;183mfind\u001b[39m output through their         "
[416] (w=84) " existing TUI renderers and \u001b[38;2;138;190;183mls\u001b[39m output through a native template renderer, avoiding  "
[417] (w=84) " missing formatting and spacing artifacts in shared sessions (\u001b]8;;https://github.com/badlogic/pi-mono/pull/3491\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3491\u001b[24m\u001b[39m\u001b]8;;\u001b\\ by \u001b]8;;https://github.com/aliou\u001b\\\u001b[38;2;129;162;190m\u001b[4m@aliou\u001b[24m\u001b[39m\u001b]8;;\u001b\\)      "
[418] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183m@\u001b[39m autocomplete fuzzy search to follow symlinked directories and include    "
[419] (w=84) " symlinked paths in results (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3507\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3507\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                 "
[420] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed proxied agent streams to preserve the proxy-safe serializable subset of    "
[421] (w=84) " stream options, including session, transport, retry-delay, metadata, header,       "
[422] (w=84) " cache-retention, and thinking-budget settings (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3512\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3512\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                              "
[423] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mHardened Anthropic streaming against malformed tool-call JSON by owning SSE      "
[424] (w=84) " parsing with defensive JSON repair, replacing the deprecated                       "
[425] (w=84) " \u001b[38;2;138;190;183mfine-grained-tool-streaming\u001b[39m beta header with per-tool \u001b[38;2;138;190;183meager_input_streaming\u001b[39m, and   "
[426] (w=84) " updating stale test model references (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3175\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3175\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                       "
[427] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed Bedrock runtime endpoint resolution to stop pinning built-in regional      "
[428] (w=84) " endpoints over \u001b[38;2;138;190;183mAWS_REGION\u001b[39m / \u001b[38;2;138;190;183mAWS_PROFILE\u001b[39m, restoring \u001b[38;2;138;190;183mus.*\u001b[39m and \u001b[38;2;138;190;183meu.*\u001b[39m inference profile "
[429] (w=84) " support after v0.68.0 while preserving custom VPC/proxy endpoint overrides (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3481\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3481\u001b[24m\u001b[39m\u001b]8;;\u001b\\, "
[430] (w=84) " \u001b]8;;https://github.com/badlogic/pi-mono/issues/3485\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3485\u001b[24m\u001b[39m\u001b]8;;\u001b\\, \u001b]8;;https://github.com/badlogic/pi-mono/issues/3486\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3486\u001b[24m\u001b[39m\u001b]8;;\u001b\\, \u001b]8;;https://github.com/badlogic/pi-mono/issues/3487\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3487\u001b[24m\u001b[39m\u001b]8;;\u001b\\, \u001b]8;;https://github.com/badlogic/pi-mono/issues/3488\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3488\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                        "
