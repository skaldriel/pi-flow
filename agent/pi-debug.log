[389] (w=84) " \u001b[38;2;240;198;116m\u001b[1m### \u001b[22m\u001b[39m\u001b[38;2;240;198;116m\u001b[1mNew Features\u001b[22m\u001b[39m                                                                   "
[390] (w=84) "                                                                                    "
[391] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFireworks provider support with built-in models and \u001b[38;2;138;190;183mFIREWORKS_API_KEY\u001b[39m auth. See  "
