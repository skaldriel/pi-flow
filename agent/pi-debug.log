[496] (w=84) "                                                                                    "
[497] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mChanged \u001b[38;2;138;190;183mpi update\u001b[39m to batch npm package updates per scope and run git package     "
[498] (w=84) " updates with bounded parallelism, reducing multi-package update time while         "
[499] (w=84) " preserving skip behavior for pinned and already-current packages (\u001b]8;;https://github.com/badlogic/pi-mono/issues/2980\u001b\\\u001b[38;2;129;162;190m\u001b[4m#2980\u001b[24m\u001b[39m\u001b]8;;\u001b\\)           "
[500] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mChanged Bedrock session requests to omit \u001b[38;2;138;190;183mmaxTokens\u001b[39m when model token limits are   "
[501] (w=84) " unknown and to omit \u001b[38;2;138;190;183mtemperature\u001b[39m when unset, letting Bedrock use provider defaults  "
[502] (w=84) " and avoid unnecessary TPM quota reservation (\u001b]8;;https://github.com/badlogic/pi-mono/pull/3400\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3400\u001b[24m\u001b[39m\u001b]8;;\u001b\\ by \u001b]8;;https://github.com/wirjo\u001b\\\u001b[38;2;129;162;190m\u001b[4m@wirjo\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                      "
