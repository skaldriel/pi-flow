[517] (w=84) " \u001b[38;2;138;190;183minstall <pkg>@latest\u001b[39m (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3000\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3000\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                       "
[518] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183m@\u001b[39m autocomplete plain queries to stop matching against the full cwd/base    "
[519] (w=84) " path, so path fragments in worktree names no longer crowd out intended results     "
[520] (w=84) " such as \u001b[38;2;138;190;183m@plan\u001b[39m (\u001b]8;;https://github.com/badlogic/pi-mono/issues/2778\u001b\\\u001b[38;2;129;162;190m\u001b[4m#2778\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                              "
[521] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed built-in tool wrapping to use the same extension-runner context path as    "
