[256] (w=84) " prompt (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3606\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3606\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                                     "
[257] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed session replacement and \u001b[38;2;138;190;183m/quit\u001b[39m teardown ordering to run host-owned          "
[258] (w=84) " extension UI cleanup synchronously after \u001b[38;2;138;190;183msession_shutdown\u001b[39m handlers complete but    "
[259] (w=84) " before invalidating the old extension context, preventing stale extension UI from  "
[260] (w=84) " rendering against a disposed session (\u001b]8;;https://github.com/badlogic/pi-mono/pull/3597\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3597\u001b[24m\u001b[39m\u001b]8;;\u001b\\ by \u001b]8;;https://github.com/vegarsti\u001b\\\u001b[38;2;129;162;190m\u001b[4m@vegarsti\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                          "
[261] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed crash on \u001b[38;2;138;190;183m/quit\u001b[39m when an extension registers a custom footer whose \u001b[38;2;138;190;183mrender()\u001b[39m  "
