[505] (w=84) "                                                                                    "
[506] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183mAgentSession\u001b[39m system-prompt option initialization to avoid constructing an  "
[507] (w=84) " invalid empty \u001b[38;2;138;190;183mBuildSystemPromptOptions\u001b[39m, so \u001b[38;2;138;190;183mnpm run check\u001b[39m passes after \u001b[38;2;138;190;183mcwd\u001b[39m became   "
[508] (w=84) " mandatory.                                                                         "
[509] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed shell-path resolution to stop consulting ambient \u001b[38;2;138;190;183mprocess.cwd()\u001b[39m state       "
