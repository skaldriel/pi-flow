[531] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed OpenAI-compatible Chat Completions sessions to optionally send aligned     "
[532] (w=84) " \u001b[38;2;138;190;183msession_id\u001b[39m, \u001b[38;2;138;190;183mx-client-request-id\u001b[39m, and \u001b[38;2;138;190;183mx-session-affinity\u001b[39m headers from \u001b[38;2;138;190;183msessionId\u001b[39m via "
