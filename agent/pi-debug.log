[289] (w=84) " (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3586\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3586\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                                            "
