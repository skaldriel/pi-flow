[475] (w=84) " extension, and updated extension/TUI/RPC docs (\u001b]8;;https://github.com/badlogic/pi-mono/issues/3413\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3413\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                              "
[476] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mAdded \u001b[38;2;138;190;183msystemPromptOptions\u001b[39m (\u001b[38;2;138;190;183mBuildSystemPromptOptions\u001b[39m) to \u001b[38;2;138;190;183mbefore_agent_start\u001b[39m       "
[477] (w=84) " extension events, so extensions can inspect the structured inputs used to build    "
[478] (w=84) " the current system prompt (\u001b]8;;https://github.com/badlogic/pi-mono/pull/3473\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3473\u001b[24m\u001b[39m\u001b]8;;\u001b\\ by \u001b]8;;https://github.com/dljsjr\u001b\\\u001b[38;2;129;162;190m\u001b[4m@dljsjr\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                       "
[479] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mAdded \u001b[38;2;138;190;183m/clone\u001b[39m to duplicate the current active branch into a new session, while    "
[480] (w=84) " keeping \u001b[38;2;138;190;183m/fork\u001b[39m focused on forking from a previous user message (\u001b]8;;https://github.com/badlogic/pi-mono/issues/2962\u001b\\\u001b[38;2;129;162;190m\u001b[4m#2962\u001b[24m\u001b[39m\u001b]8;;\u001b\\)              "
[481] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mAdded \u001b[38;2;138;190;183mctx.fork()\u001b[39m support for \u001b[38;2;138;190;183mposition: \"before\" | \"at\"\u001b[39m so extensions and         "
[482] (w=84) " integrations can branch before a user message or duplicate the current point in    "
[483] (w=84) " the conversation; the interactive clone/fork UX builds on that runtime support     "
[484] (w=84) " (\u001b]8;;https://github.com/badlogic/pi-mono/pull/3431\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3431\u001b[24m\u001b[39m\u001b]8;;\u001b\\ by \u001b]8;;https://github.com/mitsuhiko\u001b\\\u001b[38;2;129;162;190m\u001b[4m@mitsuhiko\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                              "
[485] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mAdded configurable keybinding ids for scoped model selector actions and tree     "
[486] (w=84) " filter actions, so those interactive shortcuts can be remapped in \u001b[38;2;138;190;183mkeybindings.json "
[487] (w=84) " \u001b[38;2;138;190;183m\u001b[39m (\u001b]8;;https://github.com/badlogic/pi-mono/pull/3343\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3343\u001b[24m\u001b[39m\u001b]8;;\u001b\\ by \u001b]8;;https://github.com/mpazik\u001b\\\u001b[38;2;129;162;190m\u001b[4m@mpazik\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                                "
[488] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mAdded \u001b[38;2;138;190;183mPI_OAUTH_CALLBACK_HOST\u001b[39m support for built-in OAuth login flows, allowing    "
[489] (w=84) " local callback servers used by \u001b[38;2;138;190;183mpi auth\u001b[39m to bind to a custom interface instead of    "
[490] (w=84) " hardcoded \u001b[38;2;138;190;183m127.0.0.1\u001b[39m (\u001b]8;;https://github.com/badlogic/pi-mono/pull/3409\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3409\u001b[24m\u001b[39m\u001b]8;;\u001b\\ by \u001b]8;;https://github.com/Michaelliv\u001b\\\u001b[38;2;129;162;190m\u001b[4m@Michaelliv\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                         "
[491] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mAdded \u001b[38;2;138;190;183mreason\u001b[39m and \u001b[38;2;138;190;183mtargetSessionFile\u001b[39m metadata to \u001b[38;2;138;190;183msession_shutdown\u001b[39m extension        "
[492] (w=84) " events, so extensions can distinguish quit, reload, new-session, resume, and fork  "
[493] (w=84) " teardown paths (\u001b]8;;https://github.com/badlogic/pi-mono/issues/2863\u001b\\\u001b[38;2;129;162;190m\u001b[4m#2863\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                             "
