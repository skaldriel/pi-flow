[599] (w=84) "                                                                                    "
[600] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183m/scoped-models\u001b[39m Alt+Up/Down to stay a no-op in the implicit \u001b[38;2;138;190;183mall enabled\u001b[39m     "
