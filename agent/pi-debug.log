[271] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed remaining hardcoded \u001b[38;2;138;190;183mpi\u001b[39m / \u001b[38;2;138;190;183m.pi\u001b[39m branding to route through \u001b[38;2;138;190;183mAPP_NAME\u001b[39m and        "
[272] (w=84) " \u001b[38;2;138;190;183mCONFIG_DIR_NAME\u001b[39m extension points, so SDK rebrands get consistent naming in \u001b[38;2;138;190;183m/quit\u001b[39m   "
[273] (w=84) " description, \u001b[38;2;138;190;183mprocess.title\u001b[39m, and the project-local extensions directory (\u001b]8;;https://github.com/badlogic/pi-mono/pull/3583\u001b\\\u001b[38;2;129;162;190m\u001b[4m#3583\u001b[24m\u001b[39m\u001b]8;;\u001b\\ by   "
[274] (w=84) " \u001b]8;;https://github.com/jlaneve\u001b\\\u001b[38;2;129;162;190m\u001b[4m@jlaneve\u001b[24m\u001b[39m\u001b]8;;\u001b\\)                                                                          "
[275] (w=84) " \u001b[38;2;138;190;183m- \u001b[39mFixed \u001b[38;2;138;190;183mpi-coding-agent\u001b[39m shipping \u001b[38;2;138;190;183muuid@11\u001b[39m, which triggered \u001b[38;2;138;190;183mnpm audit\u001b[39m moderate       "
